rules_version = '2';

// Tek hane senaryosu: Emre & Sıla için anonymous auth ile erişim.
// Authenticated kullanıcılar tüm household + alt koleksiyonları okuyup yazabilir.
// Email/Password auth + member-bazlı izolasyon ileride eklenebilir.

service cloud.firestore {
  match /databases/{database}/documents {

    match /households/{householdId} {
      allow read, write: if request.auth != null;

      match /{collection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
